{
  "name": "digivols-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Pacotes compartilhados do ecossistema Digivolution (CommHub/Facilities-Hub, ProBarber, Beauty, Catálogo Plus)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "workspaces": [
    "packages/*"
  ]
}
